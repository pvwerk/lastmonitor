{
  "poll_interval_s": 5.0,
  "modbus": {
    "profile": "nativ",
    "host": "192.168.1.50",
    "port": 503,
    "unit_id": 1,
    "function": "input",
    "datatype": "int32",
    "byte_order": "big",
    "word_order": "big",
    "power_scale": 0.001,
    "invert_sign": false,
    "grid_mode": "analyzer",
    "registers": {
      "power_total": 2,
      "production": 0,
      "analyzer": 19,
      "tagesertrag": 4,
      "tagesverbrauch": 6,
      "gesamtertrag": 8,
      "gesamtertrag_exp": 10,
      "gesamtverbrauch": 11,
      "gesamtverbrauch_exp": 13,
      "power_l1": null,
      "power_l2": null,
      "power_l3": null,
      "current_l1": null,
      "current_l2": null,
      "current_l3": null
    }
  },
  "limits": {
    "max_power_kw": 43,
    "warn_percent": 80,
    "critical_percent": 95
  },
  "display": {
    "title": "Netzbezug",
    "warn_text": "Achtung – Leistung beobachten",
    "critical_text": "STROM REDUZIEREN!",
    "standby": {
      "enabled": false,
      "days": {
        "mon": { "on": "06:00", "off": "23:00", "same_as_prev": false },
        "tue": { "on": "06:00", "off": "23:00", "same_as_prev": true },
        "wed": { "on": "06:00", "off": "23:00", "same_as_prev": true },
        "thu": { "on": "06:00", "off": "23:00", "same_as_prev": true },
        "fri": { "on": "06:00", "off": "23:00", "same_as_prev": true },
        "sat": { "on": "07:00", "off": "23:59", "same_as_prev": false },
        "sun": { "on": "07:00", "off": "22:00", "same_as_prev": true }
      }
    }
  },
  "sms": {
    "enabled": false,
    "provider": "seven",
    "api_key": "",
    "sender": "Lastmonitor",
    "phone_number": "",
    "threshold_percent": 95,
    "cooldown_minutes": 15,
    "notify_recovery": true,
    "notify_connection_loss": true,
    "connection_loss_after_minutes": 3
  },
  "meters": [],
  "remote_report": {
    "enabled": false,
    "endpoint": "https://crm.photovoltaikwerk.de/api/external/device-report",
    "secret": "",
    "device_source": "lastmonitor-sampl",
    "interval_s": 60
  }
}
